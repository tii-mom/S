{
  "name": "@shore/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "build": "wrangler deploy --dry-run --env=\"\" --outdir dist",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "db:migrate:local": "wrangler d1 migrations apply shore-local --local",
    "db:migrate:staging": "wrangler d1 migrations apply shore-staging --remote --env staging",
    "db:migrate:production": "wrangler d1 migrations apply shore-production --remote --env production",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings worker-configuration.d.ts"
  },
  "dependencies": {
    "@shore/shared": "workspace:*",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.3.0",
    "hono": "4.12.28",
    "tweetnacl": "^1.0.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260723.1",
    "wrangler": "4.114.0"
  }
}
